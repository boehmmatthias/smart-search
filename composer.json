{
  "name": "boehmmatthias/smartsearch",
  "description": "Generic vector embedding, semantic search and RAG infrastructure for TYPO3",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "version": "0.1.0",
  "keywords": ["typo3", "semantic-search", "vector", "rag", "llama", "embeddings"],
  "require": {
    "php": "^8.4",
    "typo3/cms-core": "^14"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "BoehmMatthias\\SmartSearch\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BoehmMatthias\\SmartSearch\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "smart_search"
    }
  },
  "config": {
    "vendor-dir": ".Build/vendor",
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": false
    }
  }
}
